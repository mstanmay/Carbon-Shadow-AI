# Database Connection
DATABASE_URL=postgresql://postgres:your_secure_password_here@localhost:5432/carbon_shadow

# Security & JWT Authentication
# Generate with: python -c "import os; print(os.urandom(32).hex())"
JWT_SECRET=generate-a-cryptographically-secure-random-secret-here

# Token Expiry
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate Limiting
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_SIMULATION=30/minute
RATE_LIMIT_GENERAL=60/minute

# OpenAI API Key for LangGraph agents
# Set to 'mock' to use deterministic fallback agents (no API calls)
# Set to a real key (sk-...) to enable GPT-4o reasoning in agents
OPENAI_API_KEY=mock

# Blockchain — Polygon Amoy Testnet
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology/
CONTRACT_ADDRESS=

# Voice AI (Optional)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=centralindia
ELEVENLABS_KEY=
